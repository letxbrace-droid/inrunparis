{
  "version": 8,
  "name": "I&N RUN — AMOLED Dark",
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "omt": { "type": "vector", "url": "https://tiles.openfreemap.org/planet" }
  },
  "layers": [
    { "id": "bg", "type": "background", "paint": { "background-color": "#0a0b0d" } },

    { "id": "water", "type": "fill", "source": "omt", "source-layer": "water",
      "paint": { "fill-color": "#0d1622" } },
    { "id": "waterway", "type": "line", "source": "omt", "source-layer": "waterway",
      "paint": { "line-color": "#0d1622", "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.8, 16, 4] } },

    { "id": "wood", "type": "fill", "source": "omt", "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": { "fill-color": "#0c130e", "fill-opacity": 0.55 } },
    { "id": "park", "type": "fill", "source": "omt", "source-layer": "park",
      "paint": { "fill-color": "#0d150f", "fill-opacity": 0.7 } },
    { "id": "residential", "type": "fill", "source": "omt", "source-layer": "landuse",
      "filter": ["in", "class", "residential", "suburb", "neighbourhood"],
      "paint": { "fill-color": "#0b0c10", "fill-opacity": 0.5 } },

    { "id": "building", "type": "fill", "source": "omt", "source-layer": "building", "minzoom": 13,
      "paint": {
        "fill-color": "#161922",
        "fill-outline-color": "#1e222c",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 13, 0, 14.5, 0.75]
      } },

    { "id": "tunnel", "type": "line", "source": "omt", "source-layer": "transportation",
      "filter": ["==", "brunnel", "tunnel"],
      "paint": { "line-color": "#171a22", "line-dasharray": [2, 2],
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 16, 3] } },

    { "id": "road-minor", "type": "line", "source": "omt", "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service", "track"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": { "line-color": "#1b1e28", "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.4, 16, 3.5] } },
    { "id": "road-secondary", "type": "line", "source": "omt", "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": { "line-color": "#262a35", "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.6, 16, 5.5] } },
    { "id": "road-primary", "type": "line", "source": "omt", "source-layer": "transportation",
      "filter": ["in", "class", "primary", "trunk"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": { "line-color": "#30343f", "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.7, 16, 7] } },
    { "id": "road-motorway", "type": "line", "source": "omt", "source-layer": "transportation",
      "filter": ["==", "class", "motorway"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": { "line-color": "#3a2a1c", "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.8, 16, 8.5] } },
    { "id": "rail", "type": "line", "source": "omt", "source-layer": "transportation",
      "filter": ["==", "class", "rail"], "minzoom": 12,
      "paint": { "line-color": "#1d2029", "line-width": 1 } },

    { "id": "boundary", "type": "line", "source": "omt", "source-layer": "boundary",
      "filter": ["<=", "admin_level", 4],
      "paint": { "line-color": "#2b2f3a", "line-dasharray": [3, 2], "line-width": 1 } },

    { "id": "road-label", "type": "symbol", "source": "omt", "source-layer": "transportation_name", "minzoom": 12,
      "layout": { "symbol-placement": "line", "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"], "text-size": 11, "text-letter-spacing": 0.02 },
      "paint": { "text-color": "#948e80", "text-halo-color": "#0a0b0d", "text-halo-width": 1.6 } },

    { "id": "water-label", "type": "symbol", "source": "omt", "source-layer": "water_name",
      "layout": { "text-field": ["get", "name"], "text-font": ["Noto Sans Regular"], "text-size": 11 },
      "paint": { "text-color": "#5f80ac", "text-halo-color": "#0a0b0d", "text-halo-width": 1.4 } },

    { "id": "place-suburb", "type": "symbol", "source": "omt", "source-layer": "place",
      "filter": ["in", "class", "suburb", "neighbourhood", "quarter"], "minzoom": 12,
      "layout": { "text-field": ["get", "name"], "text-font": ["Noto Sans Regular"], "text-size": 11,
        "text-transform": "uppercase", "text-letter-spacing": 0.09 },
      "paint": { "text-color": "#8f8a7e", "text-halo-color": "#0a0b0d", "text-halo-width": 1.5 } },
    { "id": "place-city", "type": "symbol", "source": "omt", "source-layer": "place",
      "filter": ["in", "class", "city", "town", "village"],
      "layout": { "text-field": ["get", "name"], "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 12, 13, 17],
        "text-transform": "uppercase", "text-letter-spacing": 0.08 },
      "paint": { "text-color": "#d4cfc3", "text-halo-color": "#0a0b0d", "text-halo-width": 1.8 } }
  ]
}
